{
  "name": "open-agents",
  "version": "0.1.0",
  "private": true,
  "description": "Visual agent orchestration platform",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm --filter @open-agents/frontend dev",
    "dev:backend": "pnpm --filter @open-agents/backend dev",
    "build": "pnpm -r run build",
    "build:ext": "pnpm --filter @open-agents/vscode-webview build && pnpm --filter @open-agents/vscode-extension build",
    "dev:ext": "pnpm --filter @open-agents/vscode-extension dev",
    "build:bridge": "pnpm --filter @open-agents/vscode-bridge build",
    "dev:bridge": "pnpm --filter @open-agents/vscode-bridge dev",
    "build:cli": "pnpm --filter @open-agents/cli build",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}

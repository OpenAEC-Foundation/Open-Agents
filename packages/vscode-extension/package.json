{
  "name": "@open-agents/vscode-extension",
  "displayName": "Open-Agents",
  "description": "Visual agent orchestration canvas for Claude Code",
  "version": "0.1.0",
  "publisher": "impertio-studio",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-agents.openCanvas",
        "title": "Open Canvas",
        "category": "Open-Agents",
        "icon": "$(circuit-board)"
      },
      {
        "command": "open-agents.newAgent",
        "title": "New Agent",
        "category": "Open-Agents",
        "icon": "$(add)"
      },
      {
        "command": "open-agents.startBackend",
        "title": "Start Backend",
        "category": "Open-Agents",
        "icon": "$(server)"
      },
      {
        "command": "open-agents.openSettings",
        "title": "Settings",
        "category": "Open-Agents",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "open-agents",
          "title": "Open-Agents",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "open-agents": [
        {
          "id": "openAgentsExplorer",
          "name": "Open-Agents",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openAgentsExplorer",
        "contents": "Welcome to Open-Agents!\n\nVisual agent orchestration for Claude Code.\n\n[Open Canvas](command:open-agents.openCanvas)\n[Start Backend](command:open-agents.startBackend)"
      }
    ],
    "keybindings": [
      {
        "command": "open-agents.openCanvas",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "open-agents.openCanvas",
          "when": "view == openAgentsExplorer",
          "group": "navigation"
        },
        {
          "command": "open-agents.newAgent",
          "when": "view == openAgentsExplorer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Open-Agents",
      "properties": {
        "open-agents.apiUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Backend API URL"
        },
        "open-agents.defaultModel": {
          "type": "string",
          "default": "anthropic/claude-sonnet-4-6",
          "description": "Default model for new agents"
        },
        "open-agents.theme": {
          "type": "string",
          "enum": [
            "impertio",
            "neutral",
            "midnight"
          ],
          "default": "impertio",
          "description": "Canvas theme"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@open-agents/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
